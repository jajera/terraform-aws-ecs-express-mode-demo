# Local .terraform directories
.terraform/

# Terraform state files
*.tfstate
*.tfstate.*

# Terraform variable files (may contain secrets)
terraform.tfvars
*.tfvars
!*.tfvars.example

# Crash log files
crash.log
crash.*.log

# Plan output files
tfplan
*.tfplan

# Sensitive key files
*.pem

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Python test artifacts
.hypothesis/
__pycache__/
*.pyc
.pytest_cache/
